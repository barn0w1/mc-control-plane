[Unit]
Description=mc-control-plane Host API
After=network-online.target
Wants=network-online.target
PartOf=mc-control-plane.target

[Service]
Type=simple
User=opc
Group=opc
ExecStart=/usr/local/bin/mc-control-plane node-host-api
Restart=on-failure
RestartSec=5s
TimeoutStopSec=30s
NoNewPrivileges=yes
PrivateTmp=yes
UMask=0077

[Install]
WantedBy=mc-control-plane.target
